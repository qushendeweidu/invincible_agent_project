{
  "mcpServers": {
    "sequential-thinking": {
      "command": "cmd.exe",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "github": {
      "command": "cmd.exe",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "bingcn": {
      "command": "cmd.exe",
      "args": [
        "/c",
        "npx",
        "-y",
        "bing-cn-mcp"
      ]
    },
    "windows-cli": {
      "command": "cmd.exe",
      "args": [
        "/c",
        "npx",
        "-y",
        "@simonb97/server-win-cli"
      ]
    }
  }
}